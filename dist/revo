Documentation: https://github.com/jippylong12/revo
EOF
}

show_version() {
    printf 'Revo v%s\n' "$REVO_VERSION"
}

# --- Main ---
main() {
    local command="${1:-}"

    # Handle no arguments
    if [[ -z "$command" ]]; then
        show_help
        return 0
    fi

    # Shift off the command
    shift || true

    case "$command" in
        init)
            cmd_init "$@"
            ;;
        detect)
            cmd_detect "$@"
            ;;
        clone)
            cmd_clone "$@"
            ;;
        status)
            cmd_status "$@"
            ;;
        branch)
            cmd_branch "$@"
            ;;
        checkout)
            cmd_checkout "$@"
            ;;
        sync)
            cmd_sync "$@"
            ;;
        exec)
            cmd_exec "$@"
            ;;
        add)
            cmd_add "$@"
            ;;
        list)
            cmd_list "$@"
            ;;
        context)
            cmd_context "$@"
            ;;
        feature)
            cmd_feature "$@"
            ;;
        commit)
            cmd_commit "$@"
            ;;
        push)
            cmd_push "$@"
            ;;
        pr)
            cmd_pr "$@"
            ;;
        issue|issues)
            cmd_issue "$@"
            ;;
        workspace)
            cmd_workspace "$@"
            ;;
        workspaces)
            cmd_workspaces "$@"
            ;;
        --help|-h|help)
            show_help
            ;;
        --version|-v|version)
            show_version
            ;;
        *)
            printf 'Unknown command: %s\n\n' "$command" >&2
            show_help >&2
            return 1
            ;;
    esac
}

main "$@"
